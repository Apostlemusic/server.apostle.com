{
    "info": {
        "name": "Apostle - User Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000/api"
        },
        {
            "key": "accessToken",
            "value": ""
        },
        {
            "key": "refreshToken",
            "value": ""
        },
        {
            "key": "userId",
            "value": ""
        },
        {
            "key": "songId",
            "value": ""
        },
        {
            "key": "trackId",
            "value": ""
        },
        {
            "key": "categoryId",
            "value": ""
        },
        {
            "key": "categorySlug",
            "value": ""
        },
        {
            "key": "genreSlug",
            "value": ""
        },
        {
            "key": "playlistId",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "User",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "register"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Test User\",\n  \"phoneNumber\": \"+1234567890\"\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
                        }
                    }
                },
                {
                    "name": "Verify OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/verifyOtp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "verifyOtp"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\"\n}"
                        }
                    }
                },
                {
                    "name": "Resend OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/resendOtp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "resendOtp"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\"\n}"
                        }
                    }
                },
                {
                    "name": "Forgot Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/forgotPassword",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "forgotPassword"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\"\n}"
                        }
                    }
                },
                {
                    "name": "Reset Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/resetPassword",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "resetPassword"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword123!\"\n}"
                        }
                    }
                },
                {
                    "name": "Verify Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/verifyToken",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "verifyToken"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"token\": \"{{accessToken}}\"\n}"
                        }
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/user/logout",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "logout"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Account",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/user/account",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "account"
                            ]
                        }
                    }
                },
                {
                    "name": "Profile Me",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/user/profile/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "user",
                                "profile",
                                "me"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Content (Browse)",
            "item": [
                {
                    "name": "Get All Songs",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/songs",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "songs"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Song By Id",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/songs/{{songId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "songs",
                                "{{songId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Search Songs",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/songs/search/{{query}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "songs",
                                "search",
                                "{{query}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Categories - All",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/categories",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "categories"
                            ]
                        }
                    }
                },
                {
                    "name": "Category By Slug",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/categories/{{categorySlug}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "categories",
                                "{{categorySlug}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Playlists - Get All",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/playlists",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "playlists"
                            ]
                        }
                    }
                },
                {
                    "name": "Discover",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/content/discover",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "discover"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}