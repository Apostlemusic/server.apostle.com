{
    "info": {
        "name": "Apostle - Admin Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000/api"
        },
        {
            "key": "adminAccessToken",
            "value": ""
        },
        {
            "key": "categoryId",
            "value": ""
        },
        {
            "key": "categorySlug",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "admin",
                                "register"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Admin\",\n  \"phoneNumber\": \"+1234567890\"\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "admin",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Platform",
            "item": [
                {
                    "name": "Server Stats",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{adminAccessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/stats",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "admin",
                                "stats"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Category Management",
            "item": [
                {
                    "name": "Create Category",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{adminAccessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/content/categories",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "categories"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Gospel\",\n  \"imageUrl\": \"https://example.com/category.jpg\"\n}"
                        }
                    }
                },
                {
                    "name": "Delete Category",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{adminAccessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/content/categories",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "content",
                                "categories"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"id\": \"{{categoryId}}\"\n}"
                        }
                    }
                }
            ]
        }
    ]
}