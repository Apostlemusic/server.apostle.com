{
  "info": {
    "name": "Apostle API - User, Content & Artist",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "podcasterId", "value": "" },
    { "key": "podcasterName", "value": "" },
    { "key": "podcastId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "artistId", "value": "" },
    { "key": "songId", "value": "" },
    { "key": "albumId", "value": "" },
    { "key": "trackId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "categorySlug", "value": "" },
    { "key": "genreSlug", "value": "" },
    { "key": "playlistId", "value": "" }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/register", "host": ["{{baseUrl}}"], "path": ["user", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Test User\",\n  \"phoneNumber\": \"+1234567890\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/login", "host": ["{{baseUrl}}"], "path": ["user", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/verifyOtp", "host": ["{{baseUrl}}"], "path": ["user", "verifyOtp"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/resendOtp", "host": ["{{baseUrl}}"], "path": ["user", "resendOtp"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/forgotPassword", "host": ["{{baseUrl}}"], "path": ["user", "forgotPassword"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/resetPassword", "host": ["{{baseUrl}}"], "path": ["user", "resetPassword"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/verifyToken", "host": ["{{baseUrl}}"], "path": ["user", "verifyToken"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{accessToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/user/logout", "host": ["{{baseUrl}}"], "path": ["user", "logout"] }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/user/account", "host": ["{{baseUrl}}"], "path": ["user", "account"] }
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user/getUsers", "host": ["{{baseUrl}}"], "path": ["user", "getUsers"] }
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user/getUser/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user", "getUser", "{{userId}}"] }
          }
        },
        {
          "name": "Profile Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user/profile/me", "host": ["{{baseUrl}}"], "path": ["user", "profile", "me"] }
          }
        },
        {
          "name": "Is Verified",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/isVerified?email=test@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["user", "isVerified"],
              "query": [{ "key": "email", "value": "test@example.com" }]
            }
          }
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Get All Songs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/songs", "host": ["{{baseUrl}}"], "path": ["content", "songs"] }
          }
        },
        {
          "name": "Get Song By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/songs/{{songId}}", "host": ["{{baseUrl}}"], "path": ["content", "songs", "{{songId}}"] }
          }
        },
        {
          "name": "Get Song By TrackId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/songs/track/{{trackId}}", "host": ["{{baseUrl}}"], "path": ["content", "songs", "track", "{{trackId}}"] }
          }
        },
        {
          "name": "Search Songs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/songs/search/{{query}}", "host": ["{{baseUrl}}"], "path": ["content", "songs", "search", "{{query}}"] }
          }
        },
        {
          "name": "Songs By Category",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/songs/category/{{category}}", "host": ["{{baseUrl}}"], "path": ["content", "songs", "category", "{{category}}"] }
          }
        },
        {
          "name": "Categories - All",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/categories", "host": ["{{baseUrl}}"], "path": ["content", "categories"] }
          }
        },
        {
          "name": "Category By Slug",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/categories/{{categorySlug}}", "host": ["{{baseUrl}}"], "path": ["content", "categories", "{{categorySlug}}"] }
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/content/categories", "host": ["{{baseUrl}}"], "path": ["content", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gospel\",\n  \"imageUrl\": \"https://example.com/category.jpg\"\n}"
            }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/content/categories", "host": ["{{baseUrl}}"], "path": ["content", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categorySlug\": \"{{categorySlug}}\",\n  \"name\": \"Updated Category\",\n  \"imageUrl\": \"https://example.com/category-updated.jpg\"\n}"
            }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/content/categories", "host": ["{{baseUrl}}"], "path": ["content", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Genres - All",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/genres", "host": ["{{baseUrl}}"], "path": ["content", "genres"] }
          }
        },
        {
          "name": "Genre By Slug",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/genres/{{genreSlug}}", "host": ["{{baseUrl}}"], "path": ["content", "genres", "{{genreSlug}}"] }
          }
        },
        {
          "name": "Playlists - Get All (User)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/playlists", "host": ["{{baseUrl}}"], "path": ["content", "playlists"] }
          }
        },
        {
          "name": "Playlists - Get One",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/playlists/{{playlistId}}", "host": ["{{baseUrl}}"], "path": ["content", "playlists", "{{playlistId}}"] }
          }
        },
        {
          "name": "Discover",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/discover", "host": ["{{baseUrl}}"], "path": ["content", "discover"] }
          }
        },
        {
          "name": "Discover - Jump Back In (songs)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=jump-back-in&type=song&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "jump-back-in" },
                { "key": "type", "value": "song" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Discover - Jump Back In (category)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=jump-back-in&type=category&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "jump-back-in" },
                { "key": "type", "value": "category" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Discover - New Releases",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=new-releases&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "new-releases" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Discover - Most Liked",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=most-liked&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "most-liked" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Discover - Most Listened (songs)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=most-listened&type=song&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "most-listened" },
                { "key": "type", "value": "song" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Discover - Most Listened (category)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=most-listened&type=category&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "most-listened" },
                { "key": "type", "value": "category" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Discover - Podcasts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/content/discover?section=podcasts&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "discover"],
              "query": [
                { "key": "section", "value": "podcasts" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
