{
    "info": {
        "name": "Apostle - Podcaster Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000/api"
        },
        {
            "key": "accessToken",
            "value": ""
        },
        {
            "key": "refreshToken",
            "value": ""
        },
        {
            "key": "podcasterId",
            "value": ""
        },
        {
            "key": "podcastId",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/podcaster/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "podcaster",
                                "register"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"podcaster@example.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Podcaster Name\"\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/podcaster/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "podcaster",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"podcaster@example.com\",\n  \"password\": \"Password123!\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Profile",
            "item": [
                {
                    "name": "Get My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/podcaster/profile/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "podcaster",
                                "profile",
                                "me"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Podcast Management",
            "item": [
                {
                    "name": "Upload Podcast",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/podcaster/podcast/upload",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "podcaster",
                                "podcast",
                                "upload"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Podcast Title\",\n  \"author\": \"Podcaster Name\",\n  \"trackUrl\": \"https://...\",\n  \"trackImg\": \"https://...\",\n  \"category\": [\"podcast\"],\n  \"genre\": [\"talk\"],\n  \"artistIds\": [\"{{artistId}}\"]\n}"
                        }
                    }
                },
                {
                    "name": "Get My Podcasts",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/podcaster/podcast/my",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "podcaster",
                                "podcast",
                                "my"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}